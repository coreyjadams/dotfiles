# Global git config — managed by chezmoi

[init]
	defaultBranch = main

[pull]
	rebase = true

[rebase]
	autoStash = true

[color]
	ui = auto

[core]
	editor = micro
	pager = bat --paging=always

[git-town]
	# Sync feature branches by rebasing (matches pull.rebase)
	sync-feature-strategy = rebase
	# Sync perennial branches by rebasing
	sync-perennial-strategy = rebase
	# Delete remote branch after shipping
	ship-delete-tracking-branch = true
	# Push hook: push after sync (update remote tracking branches)
	sync-push-hook = true

[user]
	email = 6619961+coreyjadams@users.noreply.github.com

[alias]
	append = town append
	compress = town compress
	contribute = town contribute
	diff-parent = town diff-parent
	down = town down
	hack = town hack
	delete = town delete
	observe = town observe
	park = town park
	prepend = town prepend
	propose = town propose
	rename = town rename
	repo = town repo
	set-parent = town set-parent
	ship = town ship
	sync = town sync
	up = town up

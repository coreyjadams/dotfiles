# Global git config — managed by chezmoi

[init]
	defaultBranch = main

[pull]
	rebase = true

[rebase]
	autoStash = true

[color]
	ui = auto

[core]
	editor = micro
	pager = bat --paging=always

[git-town]
	# Sync feature branches by rebasing (matches pull.rebase)
	sync-feature-strategy = rebase
	# Sync perennial branches by rebasing
	sync-perennial-strategy = rebase
	# Delete remote branch after shipping
	ship-delete-tracking-branch = true
	# Push hook: push after sync (update remote tracking branches)
	sync-push-hook = true


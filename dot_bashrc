# Source system-wide bashrc if present (important for clusters/remote servers)
[ -f /etc/bashrc ] && source /etc/bashrc

# -- History settings --
shopt -s histappend              # append to history file, don't overwrite
HISTSIZE=10000                   # commands kept in memory
HISTFILESIZE=20000               # lines kept in ~/.bash_history
HISTCONTROL=ignoreboth:erasedups # skip duplicates and space-prefixed commands
HISTIGNORE="ls:cd:pwd:exit:clear:history"  # skip trivial commands
PROMPT_COMMAND="history -a; ${PROMPT_COMMAND:-}"  # flush history after every command

# ble.sh: Bash Line Editor (syntax highlighting, autosuggestions, etc.)
[[ $- == *i* ]] && [ -f "${XDG_DATA_HOME:-$HOME/.local/share}/blesh/ble.sh" ] && source "${XDG_DATA_HOME:-$HOME/.local/share}/blesh/ble.sh" --noattach

export PATH="$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

# Lustre cluster paths (Linux only; file is generated by chezmoi when user_lustre/group_lustre are set)
[ -f "$HOME/.env_lustre" ] && . "$HOME/.env_lustre"

# aqua: declarative CLI version manager (https://aquaproj.github.io)
export PATH="${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}/bin:$PATH"
export AQUA_GLOBAL_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/aquaproj-aqua/aqua.yaml"

# Use eza as ls when available (installed via aqua)
command -v eza &>/dev/null && alias ls='eza'

# Source user-local bash completions (not all systems auto-scan this directory)
for f in "$HOME/.local/share/bash-completion/completions/"*; do
    [ -f "$f" ] && . "$f"
done

export TERM=xterm-256color
export EDITOR=micro

eval "$(starship init bash)"

# ble.sh: attach after rest of bashrc has loaded
[[ ${BLE_VERSION-} ]] && ble-attach

#!/bin/bash
set -euo pipefail

# Re-run when aqua.yaml changes (uv version bump, etc.)
# aqua.yaml hash: {{ include "dot_config/aquaproj-aqua/aqua.yaml" | sha256sum }}

export PATH="${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}/bin:$PATH"
export AQUA_GLOBAL_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/aquaproj-aqua/aqua.yaml"

if command -v hf &>/dev/null; then
    echo "==> hf CLI is already installed"
    exit 0
fi

if ! command -v uv &>/dev/null; then
    echo "WARNING: uv not found; skipping Hugging Face CLI install." >&2
    echo "         Run 'aqua i -a' then re-run 'chezmoi apply'." >&2
    exit 0
fi

echo "==> Installing Hugging Face CLI via uv..."
if uv tool install huggingface-hub[cli]; then
    echo "==> hf CLI installed successfully"
else
    echo "WARNING: hf CLI install failed (exit $?). Re-run 'chezmoi apply' to retry." >&2
fi
